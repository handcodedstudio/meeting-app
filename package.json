{
  "name": "local-meeting-transcriber",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first macOS desktop app for meeting transcription, diarization, and analysis",
  "author": "Hand Coded Studio",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "npm run fetch:resources && electron-vite build && electron-builder --mac --arm64",
    "fetch:resources": "node scripts/fetch-whisper-model.mjs && node scripts/fetch-sherpa-models.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "sherpa-onnx-node": "^1.13.0",
    "smart-whisper": "^0.8.1",
    "ulid": "^3.0.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "lucide-vue-next": "^1.0.0",
    "memfs": "^4.57.2",
    "msw": "^2.13.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
